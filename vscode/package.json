{
  "name": "codesnippetd",
  "displayName": "codesnippetd",
  "description": "Send text selections to the codesnippetd /pipe endpoint",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "codesnippetd.sendSelection",
        "title": "Send Selection to codesnippetd"
      }
    ],
    "menus": {
      "editor/context": [
        {
          "when": "editorHasSelection",
          "command": "codesnippetd.sendSelection",
          "group": "9_cutcopypaste@99"
        }
      ]
    },
    "configuration": {
      "title": "codesnippetd",
      "properties": {
        "codesnippetd.host": {
          "type": "string",
          "default": "localhost",
          "description": "Hostname of the codesnippetd server."
        },
        "codesnippetd.port": {
          "type": "number",
          "default": 8999,
          "minimum": 1,
          "maximum": 65535,
          "description": "Port number of the codesnippetd server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.85.0",
    "typescript": "^5.3.0"
  }
}
